<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EmployeeListController">

    <top>
        <Label text="Employee List"
               style="-fx-font-size: 16; -fx-font-weight:bold;-fx-padding:10;"/>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="Add Employee" onAction="#addEmployee"/>
                <Button text="Delete Selected" onAction="#deleteSelectedEmployee"/>
            </HBox>

            <TableView fx:id="UserTable" prefHeight="400" prefWidth="600">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80" />
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="260" />
                    <TableColumn fx:id="deptColumn" text="Department" prefWidth="200" />
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>
