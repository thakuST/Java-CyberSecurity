<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: orange;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeeController">
    <top>

        <HBox prefHeight="54.0" prefWidth="900.0" spacing="10" style="-fx-padding: 10;">

            <ComboBox fx:id="topLeftMenu" promptText="Files" />

            <Region HBox.hgrow="ALWAYS" />

            <TextField fx:id="lastLoginField" editable="false" prefHeight="26.0" prefWidth="402.0" />

            <Region HBox.hgrow="ALWAYS" /> 

            <ComboBox fx:id="userMenu" prefHeight="25.0" prefWidth="105.0" promptText="User" />

        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15">

            <ImageView fx:id="emp_image"
                       fitHeight="180" fitWidth="180"
                       preserveRatio="true"
                       style="-fx-border-radius: 10; -fx-background-radius: 10;" />

            <TextField fx:id="dep_info"
                       editable="false"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: transparent;"
                       text="Department:" />

        </VBox>
    </center>

</BorderPane>