<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ManagerController"
            fx:id="rootPane"
            prefHeight="500" prefWidth="700"
            style="-fx-background-color: #f2f2f2;">

    <top>
        <HBox fx:id="headerBar"
              prefHeight="50"
              alignment="CENTER_LEFT"
              spacing="40"
              style="-fx-background-color: #2A3F54;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Employee Details" style="-fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
             onMouseClicked="#goEmployeeActivities"/>

            <Label text="Admin Details" style="-fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
             onMouseClicked="#goAdminDetails"/>

            <Label text="Alerts" style="-fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
             onMouseClicked="#goAlerts"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Label fx:id="profileLabel" text="Profile" style="-fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
               onMouseClicked="#showProfileMenu"/>
        </HBox>
    </top>

    <center>
        <StackPane>

            <!-- Dashboard (totals + survey) -->
            <VBox fx:id="dashboardBox" alignment="CENTER" spacing="25">

                <VBox alignment="CENTER" maxWidth="350" spacing="25"
                 style="-fx-background-color: #f9f9f9; -fx-background-radius: 10;
                        -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, #cccccc, 10, 0, 0, 0);">

                 <VBox alignment="CENTER" spacing="5"
                   style="-fx-background-color: #e8f3ff;-fx-background-radius:10;
                          -fx-padding: 15;">
                        <Label text="Total Employees" style="-fx-font-size: 16;-fx-font-weight: bold;"/>
                        <Label fx:id="totalEmployeesLabel" text="0" style="-fx-font-size: 24;"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="5"
                     style="-fx-background-color: #f4eaff; -fx-background-radius: 10;-fx-padding:15;">
                        <Label text="Total Admin" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Label fx:id="totalAdminsLabel"  text="0" style="-fx-font-size: 24;"/>
                    </VBox>

                </VBox>

                <VBox alignment="CENTER" maxWidth="350" spacing="10"
                 onMouseClicked="#openSurvey"
                 style="-fx-background-color:#ffffff;-fx-padding:20;
                        -fx-background-radius:10;-fx-effect:dropshadow(three-pass-box,#cccccc,8,0,0,0);
                        -fx-cursor: hand;">
                    <Label text="Survey" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                </VBox>

            </VBox>

            
            <VBox fx:id="employeeBox" alignment="TOP_CENTER" spacing="10" visible="false" managed="false">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Back to Dashboard" onAction="#goDashboard"/>
                </HBox>

                <Label text="Employee Details"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-padding: 5 0 0 0;"/>

                <TableView fx:id="userTable"
                           prefHeight="380"
                           prefWidth="650">
                    <columns>
                        <TableColumn fx:id="userIdColumn" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="userEmailColumn" text="Email" prefWidth="280"/>
                        <TableColumn fx:id="userDeptColumn" text="Department" prefWidth="260"/>
                    </columns>
                </TableView>
            </VBox>

           
            <VBox fx:id="adminBox" alignment="TOP_CENTER" spacing="10" visible="false" managed="false">

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Add Admin" onAction="#addAdmin"/>
                    <Button text="Delete Selected" onAction="#deleteSelectedAdmin"/>
                    <Button text="Back to Dashboard" onAction="#goDashboard"/>
                </HBox>

                <Label text="Admin Details"
                       style="-fx-font-size: 16;-fx-font-weight:bold;-fx-padding:5 0 0 0;"/>

                <TableView fx:id="adminTable" prefHeight="380" prefWidth="650">
                    <columns>
                        <TableColumn fx:id="adminIdColumn" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="adminEmailColumn" text="Email" prefWidth="280"/>
                        <TableColumn fx:id="adminManagerColumn" text="Assigned To" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>

        
            <VBox fx:id="alertsBox" alignment="TOP_CENTER" spacing="10" visible="false" managed="false">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Back to Dashboard" onAction="#goDashboard"/>
                </HBox>

                <Label text="Alerts"
                       style="-fx-font-size: 16;-fx-font-weight:bold;-fx-padding: 5 0 0 0;"/>

                <TableView fx:id="alertsTable" prefHeight="380" prefWidth="650">
                    <columns>
                        <TableColumn fx:id="alertIdColumn" text="Ticket ID" prefWidth="80"/>
                        <TableColumn fx:id="alertUserColumn" text="User" prefWidth="150"/>
                        <TableColumn fx:id="alertTypeColumn" text="Type" prefWidth="120"/>
                        <TableColumn fx:id="alertSeverityColumn" text="Severity" prefWidth="80"/>
                        <TableColumn fx:id="alertStatusColumn" text="Status" prefWidth="90"/>
                        <TableColumn fx:id="alertTimeColumn" text="Time" prefWidth="130"/>
                        <TableColumn fx:id="alertAssignedColumn" text="Assigned To" prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
